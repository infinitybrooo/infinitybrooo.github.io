{
  "name": "cheatguys-site",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "cache:bust": "node tools/cache-bust.mjs",
    "cache:check": "node tools/cache-bust.mjs --check",
    "context:update": "node tools/update-ai-context.mjs",
    "check": "npm run cache:check && node tools/check.mjs && npm run check:security && eslint .",
    "check:html": "html-validate \"*.html\"",
    "check:i18n": "node tools/check-i18n.mjs",
    "check:links": "node tools/check-external-links.mjs",
    "check:security": "node tools/check-security.mjs && npm run check:links",
    "check:styles": "stylelint \"css/**/*.css\"",
    "test": "playwright test",
    "test:a11y": "playwright test tests/a11y.spec.js",
    "assets:report": "node tools/assets-report.mjs",
    "assets:secrets": "node tools/generate-secret-assets.mjs",
    "assets:unused": "node tools/find-unused-assets.mjs",
    "audit:perf": "node tools/lighthouse-audit.mjs",
    "screenshots:smoke": "node tools/capture-smoke-screenshots.mjs",
    "security:audit": "npm audit --omit=optional",
    "validate": "npm run check && npm run check:html && npm run check:styles && npm run check:i18n && npm run assets:report && npm test && npm run test:a11y",
    "build": "npm run cache:bust && node tools/check.mjs",
    "dev:cloudflare": "npx wrangler pages dev . --compatibility-date=2026-07-18",
    "deploy:cloudflare": "npx wrangler pages deploy . --project-name cheatguys-cloudflare"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "eslint": "^9.31.0",
    "globals": "^15.15.0",
    "html-validate": "^11.5.6",
    "http-server": "^14.1.1",
    "lighthouse": "^13.4.0",
    "prettier": "^3.6.2",
    "sharp": "^0.35.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}
